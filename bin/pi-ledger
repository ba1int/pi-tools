#!/usr/bin/env node

import { readFileSync } from "node:fs";
import {
  loadLedgerRecords,
  renderAgentBoard,
  renderLedger,
} from "../extensions/task-ledger/core.js";
import {
  focusZellijPane,
  moveSelection,
  selectedRecord,
} from "../extensions/task-ledger/viewer.js";

const args = process.argv.slice(2);
let once = false;
let color = process.stdout.isTTY;
let path = null;

for (let index = 0; index < args.length; index += 1) {
  const argument = args[index];
  if (argument === "--once") once = true;
  else if (argument === "--plain") color = false;
  else if (argument === "--path") {
    index += 1;
    if (!args[index]) throw new Error("--path requires a value");
    path = args[index];
  } else if (argument === "-h" || argument === "--help") {
    process.stdout.write("Usage: pi-ledger [--once] [--plain] [--path FILE]\n");
    process.exit(0);
  } else {
    throw new Error(`unknown argument: ${argument}`);
  }
}

function loadSnapshot() {
  if (!path) return null;
  try {
    return JSON.parse(readFileSync(path, "utf8"));
  } catch {
    return null;
  }
}

let mode = path ? "detail" : "auto";
let selectedKey = null;

function viewState() {
  if (path) return { records: [], selected: null, view: "detail", snapshot: loadSnapshot() };
  const records = loadLedgerRecords();
  const selected = selectedRecord(records, selectedKey);
  if (selected) selectedKey = selected.key;
  const view = mode === "auto" ? (records.length > 1 ? "board" : "detail") : mode;
  return { records, selected, view, snapshot: selected?.snapshot || null };
}

function frame() {
  const state = viewState();
  const options = {
    width: process.stdout.columns || 96,
    height: process.stdout.rows || 30,
    color,
  };
  if (state.view === "board") {
    return renderAgentBoard(state.records, { ...options, selectedKey });
  }
  const footer = state.records.length > 1
    ? "b board · enter jump · q close · local only · zero extra model tokens"
    : "q close · live event feed · local only · zero extra model tokens";
  return renderLedger(state.snapshot, { ...options, footer });
}

if (once || !process.stdout.isTTY) {
  process.stdout.write(`${frame()}\n`);
  process.exit(0);
}

let closed = false;
let previous = "";
let timer;
const close = () => {
  if (closed) return;
  closed = true;
  clearInterval(timer);
  if (process.stdin.isTTY) process.stdin.setRawMode(false);
  process.stdout.write("\x1b[?25h\x1b[0m\n");
  process.exit(0);
};

process.stdout.write("\x1b[?25l");
if (process.stdin.isTTY) {
  process.stdin.setRawMode(true);
  process.stdin.resume();
  process.stdin.on("data", (chunk) => {
    const value = chunk.toString("utf8");
    if (value === "q" || value === "\x03" || value === "\x04") {
      close();
      return;
    }
    const state = viewState();
    if (value === "\x1b[A" || value === "k") {
      selectedKey = moveSelection(state.records, selectedKey, -1);
      mode = "board";
      previous = "";
      draw();
      return;
    }
    if (value === "\x1b[B" || value === "j") {
      selectedKey = moveSelection(state.records, selectedKey, 1);
      mode = "board";
      previous = "";
      draw();
      return;
    }
    if (value === "d") {
      if (state.selected) mode = "detail";
      previous = "";
      draw();
      return;
    }
    if (value === "b" || value === "\x1b") {
      if (state.records.length > 1 && state.view === "detail") {
        mode = "board";
        previous = "";
        draw();
      } else if (value === "\x1b") {
        close();
      }
      return;
    }
    if (value === "\r" || value === "\n") {
      if (state.selected?.snapshot?.paneId
          && focusZellijPane(state.selected.snapshot.paneId)) {
        close();
      } else if (state.selected) {
        mode = "detail";
        previous = "";
        draw();
      }
    }
  });
}

const draw = () => {
  const next = frame();
  if (next === previous) return;
  previous = next;
  process.stdout.write(`\x1b[2J\x1b[H${next}`);
};

timer = setInterval(draw, 250);
process.on("SIGINT", close);
process.on("SIGTERM", close);
draw();
